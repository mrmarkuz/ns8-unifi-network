{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "local>NethServer/.github:ns8-automerge"
    ],
    "packageRules": [
        {
            "matchPackageNames": ["linuxserver/unifi-network-application"],
            "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-ls(?<revision>\\d+)$"
        },
        {
            "matchDatasources": ["docker"],
            "matchPackageNames": ["mongo"],
            "allowedVersions": "8.0.*"
        }
    ]
}
